# LLM (LongCat Anthropic 兼容 API)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.longcat.chat/anthropic
LLM_MODEL=LongCat-Flash-Lite

# 高德地图开放平台 https://lbs.amap.com/
AMAP_API_KEY=your-amap-key-here

# 大众点评开放平台 https://open.dianping.com/
DIANPING_APP_KEY=your-dianping-app-key-here
DIANPING_APP_SECRET=your-dianping-app-secret-here

# 启用本地 POI 数据库（默认开启，如需纯在线模式设为 false）
USE_POI_DB=true
